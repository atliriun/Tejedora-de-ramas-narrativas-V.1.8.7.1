{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A collaborative story project.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the project."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns the project."
        },
        "editors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of UIDs who can edit the project."
        },
        "viewers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of UIDs who can view the project."
        },
        "data": {
          "type": "string",
          "description": "JSON stringified ProjectData to avoid Firestore nested limits and allow large objects."
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of the last update."
        },
        "updatedBy": {
          "type": "string",
          "description": "UID of the user who last updated the project."
        }
      },
      "required": ["name", "ownerId", "data", "updatedAt", "editors", "viewers", "updatedBy"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores collaborative projects."
    }
  }
}
